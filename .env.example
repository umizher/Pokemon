# =========================================================================
# Monitor de Lanzamientos Pokémon TCG — variables de entorno
# Copia este archivo a `.env` y rellena los valores. NUNCA subas `.env`.
# En GitHub Actions, configura estos como "Secrets".
# =========================================================================

# --- Stock providers ---------------------------------------------------
# Best Buy: API gratuita -> https://developer.bestbuy.com/  (registra una key)
BESTBUY_API_KEY=

# Target RedSky: "key" público que usa la web de Target. Es extraíble del
# storefront; déjalo vacío para usar el default conocido del proyecto.
TARGET_API_KEY=

# Walmart (afiliados, requiere aprobación) -> https://walmart.io/
WALMART_API_KEY=
# Amazon Product Advertising API 5.0 (requiere cuenta de afiliado activa)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Proxy opcional (residencial). Sin presupuesto -> déjalo vacío; los
# providers protegidos (Pokémon Center) se marcarán como "needs proxy".
HTTP_PROXY_URL=

# --- Notificaciones ----------------------------------------------------
# Discord (default): webhook del canal -> Ajustes del canal > Integraciones
DISCORD_WEBHOOK_URL=

# Telegram (opcional): crea un bot con @BotFather y obtén el chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (opcional): SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
